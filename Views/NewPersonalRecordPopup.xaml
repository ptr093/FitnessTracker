<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="FitnessTracker.Views.NewPersonalRecordPopup"
    CanBeDismissedByTappingOutsideOfPopup="False">

    <Border StrokeShape="RoundRectangle 26"
            BackgroundColor="White"
            WidthRequest="360"
            Padding="0">

        <VerticalStackLayout Spacing="0">
            <Grid BackgroundColor="#0F172A" Padding="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border BackgroundColor="#FACC15"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 999"
                        Padding="10"
                        HeightRequest="44"
                        WidthRequest="44"
                        VerticalOptions="Center">
                    <Label Text="🏆"
                           FontSize="18"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center"
                           TextColor="#0F172A" />
                </Border>

                <VerticalStackLayout Grid.Column="1"
                                     Spacing="2"
                                     Margin="12,0,0,0"
                                     VerticalOptions="Center">
                    <Label Text="Nowy rekord!"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="Świetna robota"
                           FontSize="13"
                           TextColor="#CBD5E1" />
                </VerticalStackLayout>
            </Grid>

            <VerticalStackLayout Padding="18" Spacing="14">
                <Label x:Name="ExerciseLabel"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#0F172A"
                       LineBreakMode="TailTruncation" />

                <Border StrokeShape="RoundRectangle 18"
                        BackgroundColor="#F8FAFC"
                        Stroke="#E2E8F0"
                        StrokeThickness="1"
                        Padding="14">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Poprzedni rekord"
                                   FontSize="13"
                                   TextColor="#64748B" />
                            <Label x:Name="OldRecordLabel"
                                   Grid.Column="1"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#475569" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Nowy rekord"
                                   FontSize="13"
                                   TextColor="#64748B" />
                            <Label x:Name="NewRecordLabel"
                                   Grid.Column="1"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#16A34A" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="10">
                    <Label Text="📅"
                           FontSize="14"
                           VerticalOptions="Center" />
                    <Label x:Name="DateLabel"
                           FontSize="13"
                           TextColor="#64748B"
                           VerticalOptions="Center" />
                </Grid>

                <Button Text="Super!"
                        Clicked="OnCloseClicked"
                        BackgroundColor="#0F172A"
                        TextColor="White"
                        CornerRadius="14"
                        HeightRequest="50" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>